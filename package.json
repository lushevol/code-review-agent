{
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm --filter ratan-code-review exec vitest run",
    "typecheck": "pnpm --filter ratan-code-review typecheck",
    "agent:build": "pnpm --filter ratan-code-review build",
    "agent:start": "pnpm --filter ratan-code-review start",
    "agent:dev": "pnpm --filter ratan-code-review dev",
    "verify:release": "bash scripts/verify-release.sh",
    "clean": "pnpm -r exec sh -c 'rm -rf dist'"
  },
  "devDependencies": {
    "@rslib/core": "^0.18.6"
  }
}
