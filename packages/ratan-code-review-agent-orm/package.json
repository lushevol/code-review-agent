{
  "name": "ratan-code-review-agent-orm",
  "version": "0.0.1",
  "type": "module",
  "author": "Shuai,Lu(shuai.lu@sc.com)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "push": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit push",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "clear": "rimraf node_modules",
    "demo": "tsx src/demo.ts"
  },
  "dependencies": {
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.0",
    "drizzle-orm": "^0.44.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "@types/pg": "^8.15.4",
    "drizzle-kit": "^0.31.4"
  }
}
