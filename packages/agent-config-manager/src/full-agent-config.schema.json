{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "scanPRCreatedDaysAgo": {
      "type": "number"
    },
    "scanRepoNames": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "filePathsAllowlist": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "filePathsBlocklist": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "defaultAgentConfig": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "temperature": {
          "type": "number"
        },
        "prompts": {
          "description": "Array of prompt file paths",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "evaluationTestcases": {
          "description": "Array of dataset folder paths",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "agents": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "temperature": {
            "type": "number"
          },
          "prompts": {
            "description": "Array of prompt file paths",
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "evaluationTestcases": {
            "description": "Array of dataset folder paths",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": ["agents"],
  "additionalProperties": false
}
