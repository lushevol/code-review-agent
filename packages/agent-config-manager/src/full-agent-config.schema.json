{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "scanPRCreatedDaysAgo": {
      "type": "number"
    },
    "scanRepoNames": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "openCodeReview": {
      "type": "object",
      "properties": {
        "workspaceRoot": {
          "type": "string"
        },
        "rulesPath": {
          "type": "string",
          "minLength": 1
        },
        "llm": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "format": "uri"
            },
            "token": {
              "type": "string",
              "minLength": 1
            },
            "model": {
              "type": "string",
              "minLength": 1
            },
            "useAnthropic": {
              "default": false,
              "type": "boolean"
            }
          },
          "required": [
            "url",
            "token",
            "model",
            "useAnthropic"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "rulesPath",
        "llm"
      ],
      "additionalProperties": false
    },
    "findingStorePath": {
      "type": "string"
    },
    "logging": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        "directory": {
          "type": "string",
          "minLength": 1
        },
        "retentionDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "format": {
          "type": "string",
          "enum": [
            "pretty",
            "json"
          ]
        },
        "console": {
          "type": "boolean"
        },
        "file": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "retry": {
      "type": "object",
      "properties": {
        "maxAttempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "baseDelayMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "maxDelayMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "jitterMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false
    },
    "sonarQube": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "token": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "url"
      ],
      "additionalProperties": false
    },
    "scannerSettings": {
      "type": "object",
      "properties": {
        "cve": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "sonarqubeProjectKey": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "compliance": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "rulesPath": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "mergePolicy": {
      "type": "object",
      "properties": {
        "defaultBlockingSeverities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "overrideAuthRules": {
          "type": "object",
          "properties": {
            "criticalRequiresTwoPerson": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "webhook": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "port": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "port": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "remediationTasks": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "audit": {
      "type": "object",
      "properties": {
        "retentionDays": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "feedbackDaemon": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "intervalMs": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "watch": {
      "type": "object",
      "properties": {
        "intervalMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "openCodeReview"
  ],
  "additionalProperties": false
}