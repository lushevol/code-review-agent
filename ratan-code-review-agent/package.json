{
  "name": "ratan-code-review-agent",
  "version": "0.0.1",
  "private": true,
  "license": "ISC",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "cross-env MASTRA_TELEMETRY_DISABLED=1 mastra dev",
    "demo": "cross-env MASTRA_TELEMETRY_DISABLED=1 NODE_TLS_REJECT_UNAUTHORIZED=0 tsx src/demo.ts",
    "test-api": "tsx src/mastra/agents/test-api.ts",
    "build": "rslib build",
    "mastra:build": "cross-env MASTRA_TELEMETRY_DISABLED=1 mastra build",
    "start": "cross-env MASTRA_TELEMETRY_DISABLED=1 mastra start",
    "codegen": "tsx ./src/evaluation/json-schema-generator.ts"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "mastra": "^0.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.10"
  },
  "author": "Shuai,Lu (shuai.lu@sc.com)",
  "dependencies": {
    "@ai-sdk/openai": "1.3.24",
    "@mastra/core": "^0.24.1",
    "@mastra/libsql": "^0.16.2",
    "@mastra/loggers": "^0.10.19",
    "@mastra/memory": "^0.15.11",
    "agent-config-manager": "workspace:*",
    "ai": "^4.3.19",
    "handlebars": "^4.7.8",
    "minimatch": "^10.1.1",
    "openai": "^6.9.0",
    "ratan-ado-api": "workspace:*",
    "ratan-sonarqube-api": "workspace:*",
    "rxjs": "7.8.2",
    "talisman": "^1.1.4",
    "redact-pii": "^3.4.0",
    "zod": "^4.1.12"
  },
  "keywords": []
}
