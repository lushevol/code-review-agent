{
  "name": "ratan-code-review-agent-legacy",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "author": "Shuai,Lu(shuai.lu@sc.com)",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug",
    "start:prod": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 NODE_ENV=production node dist/main",
    "lint": "eslint '{src,apps,libs,test}/**/*.ts' --fix",
    "clear": "rimraf node_modules",
    "test": "tsx src/ratan-code-review-agent/test.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "2.0.73",
    "@apollo/server": "4.12.2",
    "@nestjs/apollo": "13.1.0",
    "@nestjs/common": "11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "11.1.3",
    "@nestjs/devtools-integration": "^0.2.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "11.1.3",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/throttler": "^6.4.0",
    "ai": "^5.0.102",
    "class-transformer": "0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "1.4.7",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.44.3",
    "handlebars": "^4.7.8",
    "minimatch": "^10.0.3",
    "nest-winston": "^1.10.2",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "ratan-ado-api": "workspace:*",
    "ratan-ai-task-gateway-types": "workspace:*",
    "ratan-confluence-api": "workspace:*",
    "ratan-markdown-tool": "workspace:*",
    "ratan-code-review-agent-orm": "workspace:*",
    "ratan-orm": "workspace:*",
    "ratan-sonarqube-api": "workspace:*",
    "redact-pii": "^3.4.0",
    "redact-secrets": "^1.0.0",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.0.1",
    "rxjs": "7.8.2",
    "soap": "^1.4.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "talisman": "^1.1.4",
    "typescript": "^5.9.3",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^2.0.0",
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.29.0",
    "@nestjs/cli": "11.0.7",
    "@nestjs/schematics": "11.0.5",
    "@nestjs/testing": "11.1.3",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "5.0.3",
    "@types/jest": "29.5.14",
    "@types/node": "^24.8.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.15.4",
    "@types/supertest": "6.0.3",
    "eslint": "9.29.0",
    "eslint-plugin-prettier": "5.5.1",
    "globals": "16.2.0",
    "jest": "29.7.0",
    "openai": "^5.15.0",
    "prettier": "3.6.2",
    "ratan-ai-task-gateway-types": "workspace:^",
    "supertest": "7.1.1",
    "ts-jest": "29.4.0",
    "ts-loader": "9.5.2",
    "ts-morph": "26.0.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.35.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!main.(t|j)s",
      "!**/*.module.(t|j)s",
      "!**/*.dto.(t|j)s",
      "!**/*.entity.(t|j)s",
      "!**/*.guard.(t|j)s",
      "!**/*.response.(t|j)s",
      "!**/*.strategy.(t|j)s",
      "!**/*.args.(t|j)s",
      "!**/*.types.(t|j)s",
      "!**/*.directive.(t|j)s",
      "!**/*.plugin.(t|j)s",
      "!**/*.scalar.(t|j)s",
      "!**/*.schema.(t|j)s",
      "!**/node_modules/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
