{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "target": "ESNext",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "finding-store": ["../../packages/finding-store/src/index.ts"],
      "agent-config-manager": ["../../packages/agent-config-manager/src/index.ts"],
      "ratan-ado-api": ["../../packages/ratan-ado-api/src/index.ts"],
      "ratan-sonarqube-api": ["../../packages/ratan-sonarqube-api/src/index.ts"]
    }
  }
}
