{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "description": "The unique identifier for the test case",
      "type": "string"
    },
    "input": {
      "type": "object",
      "properties": {
        "codeChange": {
          "type": "object",
          "properties": {
            "changes": {
              "type": "string"
            },
            "newFilePath": {
              "type": "string"
            },
            "oldFilePath": {
              "type": "string"
            },
            "changeType": {
              "type": "string"
            }
          },
          "required": ["changes", "newFilePath", "oldFilePath", "changeType"],
          "additionalProperties": false
        }
      },
      "required": ["codeChange"],
      "additionalProperties": false
    },
    "expectedOutput": {
      "type": "object",
      "properties": {
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "file": {
                "description": "The file path of the error",
                "type": "string"
              },
              "line": {
                "description": "The line number of the error",
                "type": "number"
              },
              "message": {
                "description": "A description of the error",
                "type": "string"
              },
              "suggestion": {
                "description": "A suggestion to fix the error, if available",
                "type": "string"
              },
              "suggestion_code": {
                "description": "A code snippet that illustrates the suggestion, if available",
                "type": "string"
              }
            },
            "required": [
              "file",
              "line",
              "message",
              "suggestion",
              "suggestion_code"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": ["issues"],
      "additionalProperties": false
    }
  },
  "required": ["id", "input", "expectedOutput"],
  "additionalProperties": false
}
